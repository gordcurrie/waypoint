# Copy this file to .deploy.env (gitignored) and fill in your values.
# deploy.sh sources .deploy.env automatically.

# SSH host — IP address or hostname of the remote server
DEPLOY_HOST=

# SSH user (default: root)
# DEPLOY_USER=root

# Absolute path to waypoint checkout on the remote server (default: /opt/waypoint)
# DEPLOY_PATH=/opt/waypoint
