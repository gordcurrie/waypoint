# Garmin credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# InfluxDB
INFLUXDB_URL=http://localhost:8181
INFLUXDB_BUCKET=garmin
# INFLUXDB_TOKEN is for the Go client (internal/influx); local dev uses --without-auth so any value works
INFLUXDB_TOKEN=local-dev-token

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# Sync schedule (cron format, default: every 30 min)
SYNC_SCHEDULE=*/30 * * * *

# ── Homelab deployment ────────────────────────────────────────────────────────
# Hostnames Traefik routes to this LXC (used by docker-compose.homelab.yml)
# WAYPOINT_GRAFANA_HOST=waypoint.example.com
# WAYPOINT_MCP_HOST=waypoint-mcp.example.com

# LLM provider for CLI: ollama (default, free/local), claude, openai
LLM_PROVIDER=ollama

# Ollama (local, no API key needed) — recommended default
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# Anthropic (optional — only needed if LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible (optional — only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
