# Garmin credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=waypoint
INFLUXDB_BUCKET=garmin

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# Sync schedule (cron format, default: every 30 min)
SYNC_SCHEDULE=*/30 * * * *

# MCP server transport: stdio (default, local) or sse (homelab/remote)
WAYPOINT_MCP_TRANSPORT=stdio
WAYPOINT_MCP_PORT=8080

# LLM provider for CLI: ollama (default, free/local), claude, openai
LLM_PROVIDER=ollama

# Ollama (local, no API key needed) — recommended default
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# Anthropic (optional — only needed if LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible (optional — only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
